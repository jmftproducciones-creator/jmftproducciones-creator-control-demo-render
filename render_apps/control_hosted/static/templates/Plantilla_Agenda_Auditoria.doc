<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta charset="utf-8">
</head>
<style>
    body { font-family: Arial, sans-serif; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid black; padding: 8px; text-align: center; }
    th { background-color: #8B0000; color: white; }
    .title { text-align: center; font-size: 20px; font-weight: bold; margin-bottom: 20px; color: #8B0000; }
</style>
<body>
    <div class="title">AGENDA DE AUDITORÍA</div>
    <table>
        <thead>
            <tr>
                <th>Día</th>
                <th>Hora</th>
                <th>Actividad/Proceso a auditar</th>
                <th>Lugar</th>
                <th>Auditor</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td rowspan="8">DD/MM/YY</td>
                <td>9:00</td>
                <td>Reunión de apertura</td>
                <td></td>
                <td></td>
            </tr>
            <tr>
                <td>9:30</td>
                <td>Recorrido por Planta. Comprobación de diagrama de flujo de proceso, puntos críticos, higiene y mantenimiento.</td>
                <td>Planta</td>
                <td></td>
            </tr>
            <tr>
                <td>12:30</td>
                <td colspan="3" style="font-weight: bold; background-color: #f2f2f2;">Pausa almuerzo</td>
            </tr>
            <tr>
                <td>13:00</td>
                <td>Revisión de Documentación</td>
                <td>Oficina</td>
                <td></td>
            </tr>
            <tr>
                <td>14:30</td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
            <tr>
                <td>15:30</td>
                <td>Reunión del equipo auditor</td>
                <td>Sala de Reuniones</td>
                <td></td>
            </tr>
            <tr>
                <td>16:00</td>
                <td>Reunión de cierre</td>
                <td>Sala de Reuniones</td>
                <td></td>
            </tr>
        </tbody>
    </table>
</body>
</html>
